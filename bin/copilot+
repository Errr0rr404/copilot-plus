#!/usr/bin/env node
'use strict';

const { execFile } = require('child_process');
const fs = require('fs');
const os = require('os');
const cfg = require('../src/config');
const CopilotWrapper = require('../src/wrapper');

const IS_WIN = os.platform() === 'win32';
// `which` on Unix, `where` on Windows
const WHICH = IS_WIN ? 'where' : 'which';

// ─── Setup mode ────────────────────────────────────────────────────────────────
if (process.argv.includes('--setup')) {
  runSetup(); // process exits inside runSetup via setTimeout
  return;
}

// ─── Normal mode ───────────────────────────────────────────────────────────────
const config = cfg.load();
const args = process.argv.slice(2);

const wrapper = new CopilotWrapper(args, config);
wrapper.start();

// ─── Setup helper ──────────────────────────────────────────────────────────────
function runSetup() {
  const config = cfg.load();

  console.log('\n🛠  copilot-plus setup\n');
  console.log('Checking dependencies…\n');

  let allGood = true;

  // Check copilot
  execFile(WHICH, ['copilot'], (err) => {
    if (err) {
      console.log('❌  copilot   — not found in PATH');
      console.log('     Install: https://github.com/github/copilot-cli\n');
      allGood = false;
    } else {
      console.log('✅  copilot   — found');
    }
  });

  // Check ffmpeg
  execFile(WHICH, ['ffmpeg'], (err) => {
    if (err) {
      console.log('❌  ffmpeg    — not found');
      if (IS_WIN) {
        console.log('     Install: winget install Gyan.FFmpeg\n');
      } else {
        console.log('     Install: brew install ffmpeg\n');
      }
      allGood = false;
    } else {
      console.log('✅  ffmpeg    — found');
    }
  });

  // Check whisper-cli
  execFile(WHICH, ['whisper-cli'], (err) => {
    if (err) {
      console.log('❌  whisper-cli — not found');
      if (IS_WIN) {
        console.log('     Install: https://github.com/ggerganov/whisper.cpp/releases');
        console.log('     Place whisper-cli.exe somewhere on your PATH\n');
      } else {
        console.log('     Install: brew install whisper-cpp');
        console.log('     Model:   whisper-cpp-download-ggml-model base.en\n');
      }
      allGood = false;
    } else {
      console.log('✅  whisper-cli — found');

      const model = cfg.findWhisperModel();
      if (model) {
        console.log(`✅  model        — ${model}`);
      } else {
        console.log('❌  model        — no model file found');
        console.log('     Option A: whisper-cpp-download-ggml-model base.en');
        console.log('     Option B: mkdir -p ~/.copilot/models && curl -L https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin -o ~/.copilot/models/ggml-base.en.bin\n');
        allGood = false;
      }
    }
  });

  // Print config, device picker & hotkey summary after a short delay (so async checks print first)
  setTimeout(() => {
    console.log('\n─────────────────────────────────────');
    console.log('Config:', cfg.CONFIG_PATH);
    console.log(`  modelPath:   ${config.modelPath || '(not set)'}`);
    console.log(`  autoSubmit:  ${config.autoSubmit}   (auto-press Enter after transcription)`);

    // List available audio input devices and let the user pick
    const devices = cfg.listMicDevices();
    if (devices.length === 0) {
      console.log(`  audioDevice: ${config.audioDevice}   (could not list devices — is ffmpeg installed?)`);
      console.log('\nHotkeys (inside copilot+):');
      printHotkeysAndExit(allGood);
    } else {
      console.log('\nAvailable audio input devices:');
      devices.forEach(({ id, name }, i) => {
        const marker = id === config.audioDevice ? ' ◀ current' : '';
        console.log(`  [${i + 1}] ${name}  (${id})${marker}`);
      });

      const autoIdx = devices.findIndex(d => d.id === config.audioDevice);

      // Skip interactive prompt in non-TTY environments (CI, pipes, Homebrew test)
      if (!process.stdin.isTTY) {
        console.log(`  audioDevice: ${config.audioDevice || '(not set)'}   (non-interactive — run copilot+ --setup in a terminal to pick)`);
        console.log('\nHotkeys (inside copilot+):');
        printHotkeysAndExit(allGood);
        return;
      }

      const rl = require('readline').createInterface({ input: process.stdin, output: process.stdout });
      rl.question(
        `\nChoose audio device [1-${devices.length}]${autoIdx >= 0 ? ` (Enter = keep current: ${devices[autoIdx].name})` : ''}: `,
        (answer) => {
          rl.close();
          const trimmed = answer.trim();
          if (trimmed !== '') {
            const choice = parseInt(trimmed, 10);
            if (!isNaN(choice) && choice >= 1 && choice <= devices.length) {
              const chosen = devices[choice - 1];
              // Read raw file config so we don't persist auto-detected values
              let rawConfig = {};
              try { rawConfig = JSON.parse(fs.readFileSync(cfg.CONFIG_PATH, 'utf8')); } catch {}
              rawConfig.audioDevice = chosen.id;
              cfg.save(rawConfig);
              console.log(`✅  Audio device set to: ${chosen.name}  (${chosen.id})\n`);
            } else {
              console.log('⚠️   Invalid choice — audio device unchanged.\n');
            }
          } else {
            console.log(`  Audio device unchanged: ${config.audioDevice}\n`);
          }
          console.log('Hotkeys (inside copilot+):');
          printHotkeysAndExit(allGood);
        }
      );
    }
  }, 400);
}

function printHotkeysAndExit(allGood) {
  console.log('  Ctrl+R  →  Start / stop voice recording');
  console.log('  Ctrl+P  →  Take a screenshot (injected as @path)');
  console.log('\nUsage:');
  console.log('  copilot+              →  launch copilot with voice + screenshot support');
  console.log('  copilot+ --setup      →  show this screen');
  console.log('  copilot+ --help       →  pass --help through to copilot\n');

  if (allGood) {
    console.log('✅  All dependencies found. Run `copilot+` to start!\n');
  } else {
    console.log('⚠️   Fix the issues above, then re-run `copilot+ --setup`.\n');
  }
  process.exit(0);
}
